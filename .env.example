# Copy this file to .env and fill values for your environment.

# Required for tutor responses.
GROQ_API_KEY=
gemini_api_key=
GEMINI_MODEL=gemini-3.1-flash-lite
# API auth settings (change in production).
JWT_SECRET_KEY=change-this-in-production

# Optional API settings.
HF_TOKEN=unused
API_LOG_LEVEL=info
CORS_ORIGINS_RAW=http://localhost:3000,http://localhost:5173,http://localhost:8000STORY_PROVIDER=gemini
gemini_model=gemini-3.1-flash-lite
story_provider=gemini
