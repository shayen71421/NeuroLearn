# Copy this file to .env and fill values for your environment.

# Required for tutor responses.
GROQ_API_KEY=your_key_here

# API auth settings (change in production).
JWT_SECRET_KEY=change-this-in-production

# Optional API settings.
API_LOG_LEVEL=info
CORS_ORIGINS_RAW=http://localhost:3000,http://localhost:5173,http://localhost:8000